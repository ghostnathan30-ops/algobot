# ============================================================
# AlgoBot — Git Ignore Rules
# ============================================================
# Files listed here are NEVER committed to Git.
# This protects secrets, keeps large data files local,
# and excludes auto-generated noise from the repository.

# ------------------------------------------------------------
# SECRETS — Never commit these. Ever.
# ------------------------------------------------------------
.env
*.key
*.pem
*.secret
secrets/
credentials.json
dashboard/config/auth.json
.tailscale_url
data/account_state.json

# ------------------------------------------------------------
# PYTHON — Auto-generated files
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ------------------------------------------------------------
# VIRTUAL ENVIRONMENTS — Not committed (recreated via requirements.txt)
# ------------------------------------------------------------
algobot_env/
venv/
env/
ENV/
.venv/

# ------------------------------------------------------------
# JUPYTER NOTEBOOKS — Checkpoints only (notebooks themselves ARE committed)
# ------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ------------------------------------------------------------
# DATA FILES — Too large for git, downloaded locally
# ------------------------------------------------------------
data/raw/
data/processed/
data/cache/
*.csv
*.parquet
*.h5
*.hdf5
*.pickle
*.pkl

# ------------------------------------------------------------
# REPORTS — Generated output (HTML reports regenerated by bot)
# ------------------------------------------------------------
reports/backtests/*.html
reports/validation/*.html
reports/live/*.html
reports/live/*.csv

# Logs (generated at runtime)
logs/*.log
logs/
*.log

# ------------------------------------------------------------
# TESTING
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ------------------------------------------------------------
# IDEs AND EDITORS
# ------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# WINDOWS SPECIFIC
# ------------------------------------------------------------
desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# AI TOOLS
# ------------------------------------------------------------
.claude/

# ------------------------------------------------------------
# WHAT IS COMMITTED (everything else)
# ✓ All .py source files
# ✓ All .md documentation files
# ✓ requirements.txt
# ✓ config/config.yaml
# ✓ .env.example (template only, no real keys)
# ✓ notebooks/ (without checkpoint folders)
# ✓ templates/
# ------------------------------------------------------------
