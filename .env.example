# ============================================================
# AlgoBot — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git (it is in .gitignore)
#   4. This .env.example file IS committed — it shows structure only
#
# Get free API keys at:
#   FRED:           https://fred.stlouisfed.org/docs/api/api_key.html
#   Alpha Vantage:  https://www.alphavantage.co/support/#api-key
#   QuantConnect:   https://www.quantconnect.com (free account)
#   Telegram:       Via @BotFather on Telegram app (Phase 6)
# ============================================================

# ------------------------------------------------------------
# DATA API KEYS (Required from Phase 1)
# ------------------------------------------------------------

# Federal Reserve Economic Data — free, instant sign-up
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage — free tier, 25 requests/day
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# QuantConnect — free account for backtesting
QUANTCONNECT_USER_ID=your_user_id_here
QUANTCONNECT_TOKEN=your_api_token_here

# ------------------------------------------------------------
# LIVE TRADING — Broker Credentials (Phase 6 only)
# Leave as "not_set" until Phase 6
# ------------------------------------------------------------

# Interactive Brokers (if using IBKR connection method)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Rithmic (provided by Topstep when you purchase evaluation)
RITHMIC_USER=not_set
RITHMIC_PASSWORD=not_set
RITHMIC_SERVER=not_set

# ------------------------------------------------------------
# ALERTS — Telegram Bot (Phase 6)
# See LAB_007 for setup instructions
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=not_set
TELEGRAM_CHAT_ID=not_set

# ------------------------------------------------------------
# TOPSTEP ACCOUNT INFO (Phase 7)
# ------------------------------------------------------------
TOPSTEP_ACCOUNT_ID=not_set
TOPSTEP_ACCOUNT_SIZE=50000

# ------------------------------------------------------------
# BOT OPERATING MODE
# Options: "backtest", "paper", "live"
# ALWAYS start as "backtest", only change after full validation
# ------------------------------------------------------------
BOT_MODE=backtest
