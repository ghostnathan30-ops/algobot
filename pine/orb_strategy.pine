//@version=6
// AlgoBot — Opening Range Breakout (ORB) Strategy  v2
// ⚠ DISABLED — PF=0.951 (net loser). Bar-close entry fires 5–15pts past the range boundary,
//    making avg win < avg loss structurally. Do not use for live trading.
//    Archived for reference only.
//
// Chart: NQ1! — 15m timeframe
// Range = first 30 min of RTH (9:30–10:00 ET)
// Signal = first bar after 10:00 that closes past range AND aligns with HTF EMA(50)
// Partial exit: 50% at 0.75R, 50% runs to 1.5R target
strategy("AlgoBot ORB Strategy v2", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

// ── Inputs ────────────────────────────────────────────────────────────────────
webhook_secret = input.string("CHANGE_ME_RANDOM_SECRET_HERE", "Webhook Secret")
market         = input.string("NQ", "Market", options=["ES","NQ","MNQ","MES"])
risk_mode      = input.string("safe", "Risk Mode", options=["safe","medium","hardcore"])
max_cts        = input.int(1, "Max Contracts", minval=1, maxval=5)
size_mult      = input.float(1.0, "Size Multiplier", minval=0.1, maxval=3.0, step=0.1)
orb_buffer     = input.float(0.25, "ORB Buffer (pts)", minval=0.0, step=0.25)
stop_atr_mult  = input.float(0.8, "Stop ATR Mult", minval=0.5, maxval=2.0, step=0.1)
target_r       = input.float(1.5, "Target R", minval=0.5, maxval=3.0, step=0.25)  // reduced from 2.5
partial_r      = input.float(0.75, "Partial Exit R", minval=0.25, maxval=1.5, step=0.25)
gls_score      = input.int(75, "GLS Score", minval=0, maxval=100)

// ── Time sessions (works on all timeframes via time() function) ───────────────
is_range_bar = not na(time(timeframe.period, "0930-1000", "America/New_York"))
is_entry_bar = not na(time(timeframe.period, "1000-1130", "America/New_York"))

// ── Opening range ─────────────────────────────────────────────────────────────
var float orb_high    = na
var float orb_low     = na
var bool  range_set   = false
var bool  fired_long  = false
var bool  fired_short = false

if dayofweek != dayofweek[1]
    orb_high     := na
    orb_low      := na
    range_set    := false
    fired_long   := false
    fired_short  := false

if is_range_bar
    orb_high := na(orb_high) ? high : math.max(orb_high, high)
    orb_low  := na(orb_low)  ? low  : math.min(orb_low,  low)

if is_entry_bar and not range_set and not na(orb_high)
    range_set := true

// ── ATR / HTF ─────────────────────────────────────────────────────────────────
atr14    = ta.atr(14)
htf_bull = close > ta.ema(close, 50)   // long trades: price above EMA50
htf_bear = close < ta.ema(close, 50)   // short trades: price below EMA50
htf_bias = htf_bull ? "BULL" : "BEAR"

// ── Entry / stop / target ─────────────────────────────────────────────────────
long_entry   = close
long_risk    = atr14 * stop_atr_mult
long_stop    = long_entry  - long_risk
long_tp1     = long_entry  + long_risk * partial_r   // 0.75R partial exit
long_target  = long_entry  + long_risk * target_r    // 1.5R full target

short_entry  = close
short_risk   = atr14 * stop_atr_mult
short_stop   = short_entry + short_risk
short_tp1    = short_entry - short_risk * partial_r  // 0.75R partial exit
short_target = short_entry - short_risk * target_r   // 1.5R full target

// ── Signals: breakout in direction of HTF trend only ─────────────────────────
long_signal  = range_set and is_entry_bar and barstate.isconfirmed and close > orb_high + orb_buffer and not fired_long  and htf_bull
short_signal = range_set and is_entry_bar and barstate.isconfirmed and close < orb_low  - orb_buffer and not fired_short and htf_bear

// ── Alerts ────────────────────────────────────────────────────────────────────
if long_signal
    fired_long := true
    strategy.entry("ORB Long", strategy.long, qty=max_cts)
    strategy.exit("ORB Long TP1", "ORB Long", qty_percent=50,  limit=long_tp1,   stop=long_stop)
    strategy.exit("ORB Long TP2", "ORB Long", qty_percent=100, limit=long_target, stop=long_stop)
    msg = '{"secret":"' + webhook_secret + '","market":"' + market + '","strategy":"ORB","direction":"LONG","entry":' + str.tostring(math.round(long_entry, 2)) + ',"stop":' + str.tostring(math.round(long_stop, 2)) + ',"target":' + str.tostring(math.round(long_target, 2)) + ',"size_mult":' + str.tostring(size_mult) + ',"gls_score":' + str.tostring(gls_score) + ',"htf_bias":"' + htf_bias + '","risk_mode":"' + risk_mode + '","max_contracts":' + str.tostring(max_cts) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if short_signal
    fired_short := true
    strategy.entry("ORB Short", strategy.short, qty=max_cts)
    strategy.exit("ORB Short TP1", "ORB Short", qty_percent=50,  limit=short_tp1,   stop=short_stop)
    strategy.exit("ORB Short TP2", "ORB Short", qty_percent=100, limit=short_target, stop=short_stop)
    msg = '{"secret":"' + webhook_secret + '","market":"' + market + '","strategy":"ORB","direction":"SHORT","entry":' + str.tostring(math.round(short_entry, 2)) + ',"stop":' + str.tostring(math.round(short_stop, 2)) + ',"target":' + str.tostring(math.round(short_target, 2)) + ',"size_mult":' + str.tostring(size_mult) + ',"gls_score":' + str.tostring(gls_score) + ',"htf_bias":"' + htf_bias + '","risk_mode":"' + risk_mode + '","max_contracts":' + str.tostring(max_cts) + '}'
    alert(msg, alert.freq_once_per_bar_close)

// ── Visuals ───────────────────────────────────────────────────────────────────
plot(range_set ? orb_high : na, "ORB High", color=color.new(color.green, 50), linewidth=1, style=plot.style_stepline)
plot(range_set ? orb_low  : na, "ORB Low",  color=color.new(color.red,   50), linewidth=1, style=plot.style_stepline)
plotshape(long_signal,  title="ORB LONG",  location=location.belowbar, color=color.green, style=shape.triangleup,   size=size.small)
plotshape(short_signal, title="ORB SHORT", location=location.abovebar, color=color.red,   style=shape.triangledown, size=size.small)
bgcolor(htf_bull ? color.new(color.green, 97) : color.new(color.red, 97), title="HTF Bias")
